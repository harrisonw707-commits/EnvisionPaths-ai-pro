# Gemini API Key
# For local dev: set below. For production (Cloud Run): use Google Secret Manager.
GEMINI_API_KEY=

# Stripe API Keys  
# For local dev: set below. For production (Cloud Run): use Google Secret Manager.
STRIPE_SECRET_KEY=
STRIPE_PRICE_BEGINNER_ID=
STRIPE_PRICE_PRO_ID=

# Application URL
# For local dev: leave blank or set to http://localhost:3000
# For production: set to your Cloud Run URL in Secret Manager
APP_URL=
VITE_API_URL=
