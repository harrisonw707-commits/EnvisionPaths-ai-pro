rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny - Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Global Helper Functions (Phase 3)
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches("^[a-zA-Z0-9_\\-]+$");
    }

    // Hardened Admin Check (Pillar 3/4)
    function isAdmin() {
      return isSignedIn() && (
        // Identity check against trusted email
        request.auth.token.email == "harrisonw707@gmail.com" ||
        // Relational check against user profile
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('is_admin', false) == true)
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // Validation Blueprints (Pillar 2)
    // ===============================================================

    function isValidUser(data) {
      return data.get('email', 'valid') is string && 
             data.get('plan_type', 'free') in ['free', 'pro', 'elite', 'beginner', 'basic'] &&
             data.get('created_at', request.time) is timestamp;
    }

    function isValidSimulation(data) {
      return data.get('user_id', request.auth.uid) == request.auth.uid &&
             data.get('job_title', 'valid').size() <= 200 &&
             data.get('status', 'started') in ['started', 'completed'];
    }

    function isValidMessage(data) {
      return data.get('role', 'user') in ['user', 'model', 'assistant', 'system'] &&
             data.get('text', 'valid').size() <= 50000 &&
             data.get('user_id', request.auth.uid) == request.auth.uid;
    }

    function isValidReminder(data) {
      return data.get('user_id', request.auth.uid) == request.auth.uid &&
             data.get('title', 'valid').size() <= 256 &&
             data.get('scheduled_at', request.time) is timestamp;
    }

    // ===============================================================
    // Match Rules (Phase 6)
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      allow create: if isOwner(userId) && 
                      incoming().keys().hasAll(['email', 'plan_type', 'created_at']) &&
                      isValidUser(incoming()) && 
                      (incoming().get('is_admin', false) == false || isAdmin());
      
      allow update: if (isOwner(userId) && (
                      incoming().get('created_at', existing().created_at) == existing().created_at &&
                      (incoming().get('is_admin', false) == existing().get('is_admin', false) || isAdmin())
                    )) || isAdmin();
                    
      allow delete: if isAdmin();
    }

    match /simulations/{simulationId} {
      // Secure List Queries (Pillar 8): Use where('user_id', '==', uid) in query
      allow read: if isSignedIn() && (resource.data.user_id == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && 
                      incoming().keys().hasAll(['user_id', 'job_title', 'status', 'created_at']) &&
                      isValidSimulation(incoming());
      
      allow update: if isSignedIn() && (resource.data.user_id == request.auth.uid || isAdmin()) && 
                      incoming().get('user_id', existing().user_id) == existing().user_id &&
                      incoming().get('created_at', existing().created_at) == existing().created_at;
                      
      allow delete: if isSignedIn() && (resource.data.user_id == request.auth.uid || isAdmin());

      match /messages/{messageId} {
        // Optimized Read: Check user_id on message to avoid parent lookup in lists (Pillar 1/8)
        allow read: if isSignedIn() && (resource.data.user_id == request.auth.uid || isAdmin());
        
        allow create: if isSignedIn() && 
                        incoming().keys().hasAll(['role', 'text', 'user_id', 'created_at']) &&
                        isValidMessage(incoming());
      }
    }

    match /reminders/{reminderId} {
      allow read: if isSignedIn() && (resource.data.user_id == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidReminder(incoming());
      allow update: if isSignedIn() && (resource.data.user_id == request.auth.uid || isAdmin()) && 
                      incoming().user_id == existing().user_id &&
                      incoming().created_at == existing().created_at;
      allow delete: if isSignedIn() && (resource.data.user_id == request.auth.uid || isAdmin());
    }

    match /glitch_reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && incoming().user_id == request.auth.uid;
    }

    match /activity_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && incoming().user_id == request.auth.uid;
    }

    // Connection Test
    match /_connection_test_/{docId} {
      allow read, write: if isSignedIn();
    }
  }
}
